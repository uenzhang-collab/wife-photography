---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const photos = await getCollection('photos');
const sortedPhotos = photos.sort((a, b) => b.data.date - a.data.date);
---

<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <title>經典心象 | 攝影集</title>
</head>
<body class="p-8 md:p-16">
  <header class="text-center mb-16">
    <h1 class="text-5xl font-light tracking-widest text-amber-700 mb-4">心象 | Mindscape</h1>
    <p>—— 自然地景、人文街拍與哲思的凝視</p>
  </header>
  <main class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
    {sortedPhotos.map((photo) => (
      <div class="bg-gray-300 aspect-[3/4] transition duration-500 hover:scale-[1.02] hover:-rotate-1 cursor-pointer overflow-hidden mt-0 md:mt-24 shadow-lg">
        <img src={photo.data.image} alt={photo.data.title} class="w-full h-full object-cover" />
        <div class="p-4 bg-white/80 backdrop-blur-sm">
          <h2 class="text-lg font-serif">{photo.data.title}</h2>
        </div>
      </div>
    ))}
    {sortedPhotos.length === 0 && (
      <p class="col-span-full text-center text-gray-500 italic">目前尚未有攝影作品，請透過後台新增。</p>
    )}
  </main>
</body>
</html>
